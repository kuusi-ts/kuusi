{
  "nodeModulesDir": "auto",
  "workspace": ["./src/", "./example", "./tests"],
  "tasks": {
    "publish-readme": "cp README.md src/; cd src; deno publish; rm README.md; cd ../"
  },
  "lint": {
    "rules": {
      "tags": ["recommended", "jsr"],
      "include": [
        "camelcase",
        "eqeqeq",
        "explicit-function-return-type",
        "no-const-assign",
        "no-eval"
      ]
    }
  }
}
