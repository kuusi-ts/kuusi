{
  "nodeModulesDir": "auto",
  "workspace": ["./src/", "./example", "./tests"],
  "lint": {
    "rules": {
      "tags": ["recommended", "jsr"],
      "include": [
        "camelcase",
        "eqeqeq",
        "explicit-function-return-type",
        "no-const-assign",
        "no-eval"
      ]
    }
  }
}
